# Copy to backend/.env and fill in real values. Never commit the real .env.

# Strong random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=1d

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/dementiaDB

# Port the Express API listens on
PORT=5000

# URL of the Python ML / biomarker service (Phase 2)
ML_SERVICE_URL=http://localhost:8000

# Agentic AI layer (Phase 1) — Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

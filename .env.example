# Root .env consumed by docker compose for variable substitution.
# Copy to .env to override the defaults baked into docker-compose.yml.

# Strong secret used by the backend to sign JWTs.
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Groq Cloud API key for the agentic layer (Phase 1). From https://console.groq.com
GROQ_API_KEY=
# Optional Groq overrides (defaults baked into docker-compose).
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ml-service (Phase 2) options
ALLOWED_ORIGINS=*
WHISPER_MODEL=base
